//****************** Inifile for the F/X Player v0.38 **********************
//****  you can get the latest version of the F/X Player somewhere at:  ****
// ---> http://home.pages.de/~jakob

[Soundcard]
Cardtype=SB
Adress=220
IRQ=5
DMA=5
MixingSpeed=44100

// values: Mono, Stereo, WideMono (following soon: WideStereo, Auto)
// Stereo <-> WideMono toggle: ALT-M
StereoMode=WideMono

// values: 0/off = OFF, 1/on = 1. grade (coming up: 2. grade)
// experimental: use at your own risk! toggle with ALT-I
Interpolation=on

[FX-Player]
// Directory where you have your S3M-like modules
StartUpDirectory=E:\DEMO\S3M
