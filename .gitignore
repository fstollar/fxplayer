# Release binaries (built locally, not tracked in git)
release/

# CMake build output
build/

# Web build output
build-web/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile

# DOSBox environment (Watcom binaries etc.)
_dosbox/

# Firecrawl scratch
.firecrawl/

# OS / editor artefacts
.DS_Store
Thumbs.db
.directory

# Stray build error files at repo root
*.err

# OW V2 compiler download (binaries gitignored; README tracked)
_watcom2/*
!_watcom2/README.txt

# DOSBox-X intermediate WAV captures (not ground truth)
tests/captures/

# Reference render WAVs — large binaries; sha256 hardcoded in cmake/
