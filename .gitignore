# _work/ build artefacts
_work/*.obj
_work/*.OBJ
_work/*.err
_work/*.ERR
_work/*.map
_work/*.MAP

# _original/ build artefacts (pre-built OBJs shipped in archive; ignore regenerated ones)
_original/**/*.OBJ
_original/**/*.MAP

# Claude Code project state
.claude/

# Scratch test modules (large; CTest uses committed refs in reference_renders/)
tests/_test_mods/
